# Runtime
AGENTSYSTEM_ENV=local
AGENTSYSTEM_REQUIRE_MANUAL_APPROVAL=true
AGENTSYSTEM_MAX_FIX_ATTEMPTS=2
AGENTSYSTEM_DATABASE_URL=sqlite:///data/agentsystem.db
# dev injects a server-owned local administrator. local enables password login.
AGENTSYSTEM_AUTH_MODE=dev
AGENTSYSTEM_AUTH_COOKIE_NAME=agentsystem_session
AGENTSYSTEM_AUTH_COOKIE_SECURE=false
# Set to "none" (with AGENTSYSTEM_AUTH_COOKIE_SECURE=true) when the frontend is
# hosted on a different origin (e.g. Vercel) so the browser sends the session cookie.
AGENTSYSTEM_AUTH_COOKIE_SAMESITE=lax
# Comma-separated allowed frontend origins. Empty disables the CORS middleware.
# Example for a Vercel-hosted frontend: https://agentsystem-xyz.vercel.app
AGENTSYSTEM_CORS_ORIGINS=
AGENTSYSTEM_AUTH_SESSION_TTL_HOURS=12
AGENTSYSTEM_BOOTSTRAP_ADMIN_USERNAME=admin
AGENTSYSTEM_BOOTSTRAP_ADMIN_DISPLAY_NAME=Local Administrator
# Required only for the first startup in local auth mode. Do not commit a value.
AGENTSYSTEM_BOOTSTRAP_ADMIN_PASSWORD=
# Comma-separated absolute roots. Empty means the current user's home directory in local mode.
AGENTSYSTEM_ALLOWED_PROJECT_ROOTS=
AGENTSYSTEM_WORKFLOW_POLL_INTERVAL_SECONDS=0.25
AGENTSYSTEM_WORKFLOW_LEASE_SECONDS=60

# Capability registry. HTTP MCP is limited to this exact host allowlist.
# stdio can launch local processes, so it is disabled until explicitly enabled.
AGENTSYSTEM_MCP_NETWORK_ENABLED=true
AGENTSYSTEM_MCP_ALLOWED_HOSTS=127.0.0.1,localhost,::1
AGENTSYSTEM_MCP_STDIO_ENABLED=false
AGENTSYSTEM_MCP_STDIO_ALLOWED_COMMANDS=uv,uvx,npx,node,python,python3
# Comma-separated absolute roots. Empty defaults to the current user's home.
AGENTSYSTEM_SKILL_ALLOWED_ROOTS=
AGENTSYSTEM_SKILL_MAX_BYTES=65536
AGENTSYSTEM_SKILL_PROMPT_BUDGET_CHARS=24000

# GitHub Enterprise adapter. Leave empty for mock draft PR URLs.
AGENTSYSTEM_GITHUB_ENTERPRISE_URL=
AGENTSYSTEM_GITHUB_APP_TOKEN=

# Allow explicitly configured live Agent profiles. Fresh profiles still start
# in simulated mode, so this switch alone never sends a model request.
AGENTSYSTEM_MODEL_GATEWAY_CALLS_ENABLED=true
AGENTSYSTEM_MODEL_GATEWAY_BASE_URL=
AGENTSYSTEM_MODEL_GATEWAY_DEFAULT_MODEL=private-code-model

# Per-agent bootstrap routing. Agent Studio persists later changes in SQLite.
# macOS Keychain credentials created in Agent Studio are preferred; environment
# variables remain a headless fallback and are never returned by the API.
AGENTSYSTEM_ORCHESTRATOR_MODEL_PROVIDER=openai
AGENTSYSTEM_ORCHESTRATOR_MODEL=gpt-5.6-terra
AGENTSYSTEM_ORCHESTRATOR_API_KEY_ENV=ORCHESTRATOR_AGENT_API_KEY

AGENTSYSTEM_REPO_CONTEXT_MODEL_PROVIDER=qwen
AGENTSYSTEM_REPO_CONTEXT_MODEL=qwen-plus
AGENTSYSTEM_REPO_CONTEXT_API_KEY_ENV=REPO_CONTEXT_AGENT_API_KEY

AGENTSYSTEM_PLANNING_MODEL_PROVIDER=openai
AGENTSYSTEM_PLANNING_MODEL=gpt-5.6-terra
AGENTSYSTEM_PLANNING_API_KEY_ENV=PLANNING_AGENT_API_KEY

AGENTSYSTEM_CODING_MODEL_PROVIDER=openai
AGENTSYSTEM_CODING_MODEL=gpt-5.6-sol
AGENTSYSTEM_CODING_API_KEY_ENV=CODING_AGENT_API_KEY

AGENTSYSTEM_TEST_MODEL_PROVIDER=deepseek
AGENTSYSTEM_TEST_MODEL=deepseek-v4-flash
AGENTSYSTEM_TEST_API_KEY_ENV=TEST_AGENT_API_KEY

AGENTSYSTEM_SECURITY_MODEL_PROVIDER=local-vllm
AGENTSYSTEM_SECURITY_MODEL=local-model
AGENTSYSTEM_SECURITY_MODEL_BASE_URL=http://127.0.0.1:8001/v1
AGENTSYSTEM_SECURITY_API_KEY_ENV=SECURITY_AGENT_API_KEY

AGENTSYSTEM_REVIEW_MODEL_PROVIDER=openai
AGENTSYSTEM_REVIEW_MODEL=gpt-5.6-terra
AGENTSYSTEM_REVIEW_API_KEY_ENV=REVIEW_AGENT_API_KEY

AGENTSYSTEM_PR_MODEL_PROVIDER=openai
AGENTSYSTEM_PR_MODEL=gpt-5.6-luna
AGENTSYSTEM_PR_API_KEY_ENV=PR_AGENT_API_KEY

# Example secret env vars. Do not commit real values.
ORCHESTRATOR_AGENT_API_KEY=
REPO_CONTEXT_AGENT_API_KEY=
PLANNING_AGENT_API_KEY=
CODING_AGENT_API_KEY=
TEST_AGENT_API_KEY=
SECURITY_AGENT_API_KEY=
REVIEW_AGENT_API_KEY=
PR_AGENT_API_KEY=
